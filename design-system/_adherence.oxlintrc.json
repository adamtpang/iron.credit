{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/data/**",
              "components/forms/**",
              "ui_kits/**",
              "ui_kits/app_web/**",
              "ui_kits/deck/**",
              "ui_kits/mobile/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bodoni Moda|Hanken Grotesk|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Bodoni Moda, Hanken Grotesk, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|leadingIcon|trailingIcon|disabled|full|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, leadingIcon, trailingIcon, disabled, full, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|interactive|radius|pad|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tone, interactive, radius, pad, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|hint|accent|strong|divider|style|key|ref|className|style|children)$/]",
        "message": "<DataRow> doesn't accept that prop. Declared props: label, value, hint, accent, strong, divider, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|value|onChange|placeholder|disabled|invalid|mono|prefix|suffix|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: type, value, onChange, placeholder, disabled, invalid, mono, prefix, suffix, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IronCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:width|finish|holder|last4|exp|virtual|style|key|ref|className|style|children)$/]",
        "message": "<IronCard> doesn't accept that prop. Declared props: width, finish, holder, last4, exp, virtual, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|wordmark|size|color|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, wordmark, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LTVGauge'] > JSXAttribute > JSXIdentifier[name!=/^(?:ltv|max|liqPrice|btcPrice|showHeader|height|style|key|ref|className|style|children)$/]",
        "message": "<LTVGauge> doesn't accept that prop. Declared props: ltv, max, liqPrice, btcPrice, showHeader, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|sub|delta|deltaTone|display|accent|align|style|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: label, value, sub, delta, deltaTone, display, accent, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<Stat> align must be one of 'left' | 'right'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
